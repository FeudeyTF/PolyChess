@page
@using PolyChess.Pages
@model IndexModel
@{
    ViewData["Title"] = "Профиль студента";
    Layout = "_Layout";
}

@if (!Model.IsAuthenticated)
{
    <div class="tg-error">
        <strong>Доступ запрещён</strong><br>
        @Model.ErrorMessage
    </div>
}
else if (Model.CurrentStudent == null)
{
    <div class="tg-error">
        <strong>Профиль не найден</strong><br>
        @Model.ErrorMessage
    </div>
}
else
{
    <div class="tg-header">
        <div class="tg-header-title">@Model.CurrentStudent.FullName</div>
        <div class="tg-header-subtitle">
            <i class="fa-solid fa-graduation-cap"></i> @Model.CurrentStudent.Institute, @Model.CurrentStudent.Year курс<br>
            <i class="fa-solid fa-users"></i> Группа @Model.CurrentStudent.Group
        </div>
        @if (!string.IsNullOrEmpty(Model.CurrentStudent.LichessId))
        {
            <a href="https://lichess.org/@Model.CurrentStudent.LichessId" target="_blank" class="tg-header-link">
                <i class="fa-solid fa-chess-knight"></i> Профиль на Lichess
            </a>
        }
    </div>

    <div class="tg-section">
        <div class="tg-section-header"><i class="fa-solid fa-chart-line"></i> Прогресс по зачёту</div>
        <div class="tg-section-content">
            <!-- Посещаемость -->
            <div class="tg-progress">
                <div class="tg-progress-header">
                    <span class="tg-progress-title"><i class="fa-solid fa-calendar-check"></i> Посещаемость занятий</span>
                    <span class="tg-progress-value">@Model.AttendedLessons / @Model.TotalLessons</span>
                </div>
                @{
                    var attendancePercent = Model.TotalLessons > 0
                        ? (int)((double)Model.AttendedLessons / Model.TotalLessons * 100)
                        : 0;
                    var attendanceClass = attendancePercent >= 75 ? "completed" : "";
                }
                <div class="tg-progress-bar">
                    <div class="tg-progress-fill @attendanceClass" style="width: @attendancePercent%"></div>
                </div>
                @if (attendancePercent >= 75)
                {
                    <span class="tg-badge tg-badge-success"><i class="fa-solid fa-check"></i> Выполнено (@attendancePercent%)</span>
                }
                else
                {
                    <span class="tg-badge tg-badge-warning">Требуется посещение (@attendancePercent%)</span>
                }
            </div>

            <!-- Турниры -->
            <div class="tg-progress">
                <div class="tg-progress-header">
                    <span class="tg-progress-title"><i class="fa-solid fa-trophy"></i> Турниры</span>
                    <span class="tg-progress-value">@Model.CurrentStudent.TournamentScore баллов</span>
                </div>
                @{
                    var tournamentPercent = Model.RequiredTournaments > 0
                        ? Math.Min(100, (int)((double)Model.CurrentStudent.TournamentScore / Model.RequiredTournaments * 100))
                        : 0;
                    var tournamentClass = Model.CurrentStudent.TournamentScore >= Model.RequiredTournaments ? "completed" : "";
                }
                <div class="tg-progress-bar">
                    <div class="tg-progress-fill @tournamentClass" style="width: @tournamentPercent%"></div>
                </div>
                @if (Model.CurrentStudent.TournamentScore >= Model.RequiredTournaments)
                {
                    <span class="tg-badge tg-badge-success"><i class="fa-solid fa-check"></i> Требование выполнено</span>
                }
                else
                {
                    <span class="tg-badge tg-badge-info">Требуется: @Model.RequiredTournaments баллов</span>
                }
            </div>

            <!-- Пазлы -->
            <div class="tg-progress">
                <div class="tg-progress-header">
                    <span class="tg-progress-title"><i class="fa-solid fa-puzzle-piece"></i> Решённые пазлы</span>
                    <span class="tg-progress-value">@Model.SolvedPuzzles / @Model.RequiredPuzzles</span>
                </div>
                @{
                    var puzzlePercent = Model.RequiredPuzzles > 0
                        ? Math.Min(100, (int)((double)Model.SolvedPuzzles / Model.RequiredPuzzles * 100))
                        : 0;
                    var puzzleClass = Model.SolvedPuzzles >= Model.RequiredPuzzles ? "completed" : "";
                }
                <div class="tg-progress-bar">
                    <div class="tg-progress-fill @puzzleClass" style="width: @puzzlePercent%"></div>
                </div>
                @if (Model.SolvedPuzzles >= Model.RequiredPuzzles)
                {
                    <span class="tg-badge tg-badge-success"><i class="fa-solid fa-check"></i> Требование выполнено</span>
                }
                else
                {
                    <span class="tg-badge tg-badge-info">Требуется: @Model.RequiredPuzzles пазлов</span>
                }
            </div>

            <!-- Творческое задание -->
            <div class="tg-progress">
                <div class="tg-progress-header">
                    <span class="tg-progress-title"><i class="fa-solid fa-lightbulb"></i> Творческое задание</span>
                    <span class="tg-progress-value">@(Model.CurrentStudent.CreativeTaskCompleted ? "Выполнено" : "Не выполнено")</span>
                </div>
                @if (Model.CurrentStudent.CreativeTaskCompleted)
                {
                    <span class="tg-badge tg-badge-success"><i class="fa-solid fa-check"></i> Завершено</span>
                }
                else
                {
                    <span class="tg-badge tg-badge-warning">Требуется выполнение</span>
                }
            </div>
        </div>
    </div>

    <div class="tg-section">
        <div class="tg-section-header"><i class="fa-solid fa-chart-bar"></i> Статистика</div>
        <div class="tg-stats-grid">
            <div class="tg-stat-card">
                <div class="tg-stat-value">@Model.AttendedLessons</div>
                <div class="tg-stat-label">Посещено занятий</div>
            </div>
            <div class="tg-stat-card">
                <div class="tg-stat-value">@Model.CurrentStudent.TournamentScore</div>
                <div class="tg-stat-label">Турнирные баллы</div>
            </div>
            <div class="tg-stat-card">
                <div class="tg-stat-value">@Model.SolvedPuzzles</div>
                <div class="tg-stat-label">Решено пазлов</div>
            </div>
            <div class="tg-stat-card">
                <div class="tg-stat-value">@(Model.CurrentStudent.CreativeTaskCompleted ? Html.Raw("<i class=\"fa-solid fa-check\"></i>") : Html.Raw("—"))</div>
                <div class="tg-stat-label">Творческое задание</div>
            </div>
        </div>
    </div>

    <div class="tg-section">
        <div class="tg-section-header"><i class="fa-solid fa-trophy"></i> Турниры</div>
        <div class="tg-section-content">
            @{
                var initDataParam = !string.IsNullOrEmpty(Model.InitData) ? $"?initData={Uri.EscapeDataString(Model.InitData)}" : "";
            }
            <a href="/Tournaments@(initDataParam)" class="tg-cell tg-cell-clickable">
                <div class="tg-cell-icon"><i class="fa-solid fa-list"></i></div>
                <div class="tg-cell-content">
                    <div class="tg-cell-title">Прошедшие турниры</div>
                    <div class="tg-cell-subtitle">История участия в турнирах</div>
                </div>
                <div class="tg-cell-chevron"></div>
            </a>
            <a href="/UpcomingTournaments@(initDataParam)" class="tg-cell tg-cell-clickable">
                <div class="tg-cell-icon"><i class="fa-solid fa-calendar"></i></div>
                <div class="tg-cell-content">
                    <div class="tg-cell-title">Предстоящие турниры</div>
                    <div class="tg-cell-subtitle">Расписание будущих турниров</div>
                </div>
                <div class="tg-cell-chevron"></div>
            </a>
        </div>
    </div>
}
