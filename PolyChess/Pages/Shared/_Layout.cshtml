<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
    <title>@ViewData["Title"] - PolyChess</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        :root {
            --tg-theme-bg-color: #ffffff;
            --tg-theme-text-color: #000000;
            --tg-theme-hint-color: #999999;
            --tg-theme-link-color: #3390ec;
            --tg-theme-button-color: #3390ec;
            --tg-theme-button-text-color: #ffffff;
            --tg-theme-secondary-bg-color: #f4f4f5;
            --tg-theme-header-bg-color: #ffffff;
            --tg-theme-accent-text-color: #3390ec;
            --tg-theme-section-bg-color: #ffffff;
            --tg-theme-section-header-text-color: #3390ec;
            --tg-theme-subtitle-text-color: #999999;
            --tg-theme-destructive-text-color: #e53935;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--tg-theme-bg-color);
            color: var(--tg-theme-text-color);
            padding: 0;
            margin: 0;
            overflow-x: hidden;
            line-height: 1.5;
        }

        .tg-container {
            max-width: 100%;
            padding: 0;
            padding-bottom: calc(env(safe-area-inset-bottom) + 16px);
        }

        /* Telegram UI Section styles */
        .tg-section {
            background: var(--tg-theme-section-bg-color, var(--tg-theme-secondary-bg-color));
            margin-bottom: 16px;
        }

        .tg-section-header {
            font-size: 13px;
            font-weight: 400;
            color: var(--tg-theme-section-header-text-color, var(--tg-theme-hint-color));
            text-transform: uppercase;
            padding: 8px 16px;
            padding-top: 24px;
            letter-spacing: 0.02em;
        }

        .tg-section-content {
            background: var(--tg-theme-section-bg-color, var(--tg-theme-secondary-bg-color));
        }

        /* Cell/List item styles */
        .tg-cell {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            background: var(--tg-theme-section-bg-color, var(--tg-theme-secondary-bg-color));
            position: relative;
            min-height: 48px;
        }

        .tg-cell::after {
            content: '';
            position: absolute;
            left: 16px;
            right: 0;
            bottom: 0;
            height: 0.5px;
            background: var(--tg-theme-hint-color);
            opacity: 0.2;
        }

        .tg-cell:last-child::after {
            display: none;
        }

        .tg-cell-clickable {
            cursor: pointer;
            transition: background-color 0.15s ease;
            text-decoration: none;
        }

        .tg-cell-clickable:active {
            background: var(--tg-theme-bg-color);
        }

        .tg-cell-icon {
            width: 28px;
            height: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            font-size: 20px;
        }

        .tg-cell-content {
            flex: 1;
            min-width: 0;
        }

        .tg-cell-title {
            font-size: 17px;
            font-weight: 400;
            color: var(--tg-theme-text-color);
            line-height: 1.3;
        }

        .tg-cell-subtitle {
            font-size: 14px;
            color: var(--tg-theme-subtitle-text-color, var(--tg-theme-hint-color));
            margin-top: 2px;
            line-height: 1.3;
        }

        .tg-cell-value {
            font-size: 17px;
            color: var(--tg-theme-hint-color);
            margin-left: 8px;
            flex-shrink: 0;
        }

        .tg-cell-chevron {
            width: 20px;
            height: 20px;
            margin-left: 4px;
            color: var(--tg-theme-hint-color);
            opacity: 0.6;
        }

        .tg-cell-chevron::after {
            content: '›';
            font-size: 22px;
            font-weight: 300;
        }

        /* Header / Profile card */
        .tg-header {
            background: var(--tg-theme-section-bg-color, var(--tg-theme-secondary-bg-color));
            padding: 20px 16px;
            text-align: center;
            margin-bottom: 16px;
        }

        .tg-header-title {
            font-size: 22px;
            font-weight: 600;
            color: var(--tg-theme-text-color);
            margin-bottom: 4px;
        }

        .tg-header-subtitle {
            font-size: 15px;
            color: var(--tg-theme-hint-color);
        }

        .tg-header-link {
            display: inline-flex;
            align-items: center;
            color: var(--tg-theme-link-color);
            text-decoration: none;
            font-size: 14px;
            margin-top: 8px;
        }

        /* Progress bar */
        .tg-progress {
            padding: 12px 16px;
        }

        .tg-progress-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 15px;
        }

        .tg-progress-title {
            color: var(--tg-theme-text-color);
        }

        .tg-progress-value {
            color: var(--tg-theme-hint-color);
            font-weight: 500;
        }

        .tg-progress-bar {
            background: var(--tg-theme-bg-color);
            border-radius: 4px;
            height: 6px;
            overflow: hidden;
        }

        .tg-progress-fill {
            background: var(--tg-theme-button-color);
            height: 100%;
            border-radius: 4px;
            transition: width 0.3s ease;
        }

        .tg-progress-fill.completed {
            background: #34C759;
        }

        /* Badge/Chip */
        .tg-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 500;
            margin-top: 6px;
        }

        .tg-badge-success {
            background: rgba(52, 199, 89, 0.12);
            color: #34C759;
        }

        .tg-badge-warning {
            background: rgba(255, 149, 0, 0.12);
            color: #FF9500;
        }

        .tg-badge-info {
            background: rgba(51, 144, 236, 0.12);
            color: var(--tg-theme-button-color);
        }

        .tg-badge-error {
            background: rgba(255, 59, 48, 0.12);
            color: #FF3B30;
        }

        /* Stats grid */
        .tg-stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1px;
            background: var(--tg-theme-hint-color);
            background: rgba(0,0,0,0.05);
        }

        .tg-stat-card {
            background: var(--tg-theme-section-bg-color, var(--tg-theme-secondary-bg-color));
            padding: 16px;
            text-align: center;
        }

        .tg-stat-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--tg-theme-button-color);
            margin-bottom: 4px;
        }

        .tg-stat-label {
            font-size: 13px;
            color: var(--tg-theme-hint-color);
        }

        /* Link */
        .tg-link {
            color: var(--tg-theme-link-color);
            text-decoration: none;
        }

        .tg-link:active {
            opacity: 0.7;
        }

        /* Error message */
        .tg-error {
            background: rgba(255, 59, 48, 0.08);
            color: var(--tg-theme-destructive-text-color, #FF3B30);
            padding: 16px;
            text-align: center;
            font-size: 15px;
            margin: 16px;
            border-radius: 12px;
        }

        /* Page title */
        .tg-page-title {
            font-size: 28px;
            font-weight: 700;
            color: var(--tg-theme-text-color);
            padding: 16px;
            padding-bottom: 8px;
        }

        /* Tournament card specific */
        .tournament-card {
            padding: 12px 16px;
            background: var(--tg-theme-section-bg-color, var(--tg-theme-secondary-bg-color));
            position: relative;
        }

        .tournament-card::after {
            content: '';
            position: absolute;
            left: 16px;
            right: 0;
            bottom: 0;
            height: 0.5px;
            background: var(--tg-theme-hint-color);
            opacity: 0.2;
        }

        .tournament-card:last-child::after {
            display: none;
        }

        .tournament-name {
            font-size: 16px;
            font-weight: 500;
            color: var(--tg-theme-text-color);
            margin-bottom: 4px;
        }

        .tournament-date {
            font-size: 14px;
            color: var(--tg-theme-hint-color);
            margin-bottom: 6px;
        }

        .tournament-stats {
            display: flex;
            gap: 16px;
            font-size: 13px;
            color: var(--tg-theme-hint-color);
        }

        .tournament-stat {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .tournament-score {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 24px;
            height: 24px;
            padding: 0 8px;
            background: var(--tg-theme-button-color);
            color: var(--tg-theme-button-text-color);
            border-radius: 12px;
            font-size: 13px;
            font-weight: 600;
        }

        .tournament-score.zero {
            background: var(--tg-theme-hint-color);
            opacity: 0.5;
        }

        .tournament-score.negative {
            background: var(--tg-theme-destructive-text-color, #FF3B30);
        }

        /* Tournament type badge */
        .tournament-type {
            display: inline-block;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            padding: 2px 6px;
            border-radius: 4px;
            margin-left: 8px;
            vertical-align: middle;
        }

        .tournament-type.arena {
            background: rgba(255, 149, 0, 0.12);
            color: #FF9500;
        }

        .tournament-type.swiss {
            background: rgba(51, 144, 236, 0.12);
            color: var(--tg-theme-button-color);
        }

        /* Empty state */
        .tg-empty {
            text-align: center;
            padding: 32px 16px;
            color: var(--tg-theme-hint-color);
        }

        .tg-empty-icon {
            font-size: 48px;
            margin-bottom: 12px;
            opacity: 0.5;
        }

        .tg-empty-text {
            font-size: 15px;
        }

        /* Upcoming tournament card */
        .upcoming-card {
            border-left: 3px solid var(--tg-theme-button-color);
        }

        .upcoming-time {
            font-size: 15px;
            font-weight: 600;
            color: var(--tg-theme-button-color);
        }

        /* Tournament link */
        .tournament-link {
            margin-top: 8px;
            font-size: 13px;
            color: var(--tg-theme-link-color);
        }

        .tournament-link i {
            margin-right: 4px;
        }

        /* Icon spacing in section headers */
        .tg-section-header i,
        .tg-page-title i {
            margin-right: 8px;
        }

        .tg-progress-title i,
        .tg-header-subtitle i {
            margin-right: 6px;
            width: 16px;
            text-align: center;
        }

        .tg-cell-icon i {
            color: var(--tg-theme-button-color);
        }

        .tournament-stat i {
            margin-right: 4px;
        }

        .tournament-date i {
            margin-right: 6px;
        }

        a.tournament-card {
            display: block;
            text-decoration: none;
            color: inherit;
        }

        /* Loading state - Polytechnic themed */
        .tg-loading {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 80vh;
            background: linear-gradient(135deg, rgba(0, 128, 70, 0.03) 0%, rgba(0, 100, 50, 0.08) 100%);
        }

        .poly-logo {
            position: relative;
            width: 120px;
            height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
        }

        .poly-ring {
            position: absolute;
            width: 100%;
            height: 100%;
            border: 3px solid transparent;
            border-top-color: #008046;
            border-right-color: #00a85a;
            border-radius: 50%;
            animation: polyRing 1.5s cubic-bezier(0.68, -0.55, 0.27, 1.55) infinite;
        }

        .poly-ring-inner {
            position: absolute;
            width: 80%;
            height: 80%;
            border: 2px solid transparent;
            border-bottom-color: #006838;
            border-left-color: #00c96b;
            border-radius: 50%;
            animation: polyRingReverse 1.2s cubic-bezier(0.68, -0.55, 0.27, 1.55) infinite;
        }

        .poly-pi {
            font-size: 48px;
            font-weight: 700;
            font-family: 'Times New Roman', serif;
            color: #008046;
            animation: polyPulse 2s ease-in-out infinite;
            text-shadow: 0 0 20px rgba(0, 128, 70, 0.3);
            z-index: 1;
        }

        .poly-chess {
            position: absolute;
            font-size: 14px;
            color: #008046;
            opacity: 0;
            animation: chessFloat 3s ease-in-out infinite;
        }

        .poly-chess:nth-child(1) { top: -5px; left: 50%; transform: translateX(-50%); animation-delay: 0s; }
        .poly-chess:nth-child(2) { top: 50%; right: -5px; transform: translateY(-50%); animation-delay: 0.5s; }
        .poly-chess:nth-child(3) { bottom: -5px; left: 50%; transform: translateX(-50%); animation-delay: 1s; }
        .poly-chess:nth-child(4) { top: 50%; left: -5px; transform: translateY(-50%); animation-delay: 1.5s; }

        @@keyframes polyRing {
            0% { transform: rotate(0deg) scale(1); }
            50% { transform: rotate(180deg) scale(1.05); }
            100% { transform: rotate(360deg) scale(1); }
        }

        @@keyframes polyRingReverse {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(-360deg); }
        }

        @@keyframes polyPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }

        @@keyframes chessFloat {
            0%, 100% { opacity: 0; transform: translateY(0) scale(0.8); }
            50% { opacity: 0.6; transform: translateY(-5px) scale(1); }
        }

        .tg-loading-text {
            font-size: 16px;
            font-weight: 500;
            color: #008046;
            letter-spacing: 0.5px;
        }

        .tg-loading-subtitle {
            font-size: 13px;
            color: var(--tg-theme-hint-color);
            margin-top: 8px;
            opacity: 0.8;
        }

        .tg-content {
            display: none;
        }

        .tg-content.loaded {
            display: block;
        }
    </style>
</head>
<body>
    <div class="tg-container">
        <div class="tg-loading" id="loading">
            <div class="poly-logo">
                <div class="poly-ring"></div>
                <div class="poly-ring-inner"></div>
                <div class="poly-pi">π</div>
                <i class="fa-solid fa-chess-knight poly-chess"></i>
                <i class="fa-solid fa-chess-rook poly-chess"></i>
                <i class="fa-solid fa-chess-queen poly-chess"></i>
                <i class="fa-solid fa-chess-bishop poly-chess"></i>
            </div>
            <div class="tg-loading-text">PolyChess</div>
            <div class="tg-loading-subtitle">Санкт-Петербургский Политех</div>
        </div>
        <div class="tg-content" id="content">
            @RenderBody()
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        tg.ready();
        tg.expand();
        
        function applyTheme() {
            const root = document.documentElement;
            const params = tg.themeParams;
            
            if (params.bg_color) root.style.setProperty('--tg-theme-bg-color', params.bg_color);
            if (params.text_color) root.style.setProperty('--tg-theme-text-color', params.text_color);
            if (params.hint_color) root.style.setProperty('--tg-theme-hint-color', params.hint_color);
            if (params.link_color) root.style.setProperty('--tg-theme-link-color', params.link_color);
            if (params.button_color) root.style.setProperty('--tg-theme-button-color', params.button_color);
            if (params.button_text_color) root.style.setProperty('--tg-theme-button-text-color', params.button_text_color);
            if (params.secondary_bg_color) root.style.setProperty('--tg-theme-secondary-bg-color', params.secondary_bg_color);
            if (params.header_bg_color) root.style.setProperty('--tg-theme-header-bg-color', params.header_bg_color);
            if (params.accent_text_color) root.style.setProperty('--tg-theme-accent-text-color', params.accent_text_color);
            if (params.section_bg_color) root.style.setProperty('--tg-theme-section-bg-color', params.section_bg_color);
            if (params.section_header_text_color) root.style.setProperty('--tg-theme-section-header-text-color', params.section_header_text_color);
            if (params.subtitle_text_color) root.style.setProperty('--tg-theme-subtitle-text-color', params.subtitle_text_color);
            if (params.destructive_text_color) root.style.setProperty('--tg-theme-destructive-text-color', params.destructive_text_color);
        }
        
        applyTheme();
        tg.onEvent('themeChanged', applyTheme);

        function initPage() {
            const loading = document.getElementById('loading');
            const content = document.getElementById('content');
            
            if (window.location.search.indexOf('initData') === -1 && tg.initData) {
                const url = new URL(window.location);
                url.searchParams.set('initData', tg.initData);
                window.location.href = url.toString();
                return;
            }
            
            loading.style.display = 'none';
            content.classList.add('loaded');
        }
        
        initPage();

        function setupBackButton() {
            const path = window.location.pathname.toLowerCase();
            if (path !== '/' && path !== '/index') {
                tg.BackButton.show();
                tg.BackButton.onClick(function() {
                    const initData = new URLSearchParams(window.location.search).get('initData');
                    window.location.href = '/?initData=' + encodeURIComponent(initData || '');
                });
            } else {
                tg.BackButton.hide();
            }
        }
        setupBackButton();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
