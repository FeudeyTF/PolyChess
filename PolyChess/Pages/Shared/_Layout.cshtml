<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] — Шахматный клуб СПбПУ</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        :root {
            --tg-theme-bg-color: #ffffff;
            --tg-theme-text-color: #000000;
            --tg-theme-hint-color: #999999;
            --tg-theme-link-color: #2481cc;
            --tg-theme-button-color: #2481cc;
            --tg-theme-button-text-color: #ffffff;
            --tg-theme-secondary-bg-color: #f1f1f1;
            
            --poly-accent: #00629b;
            --poly-accent-light: #3a8ec4;
            --poly-accent-dark: #004c7a;
            --poly-gold: #d4a84b;
            --poly-silver: #a8a8a8;
            --poly-bronze: #cd7f32;
            
            --card-bg: var(--tg-theme-bg-color);
            --card-border: rgba(0, 0, 0, 0.08);
            --divider: rgba(0, 0, 0, 0.06);
            --success: #31b545;
            --warning: #f5a623;
            --error: #e74c3c;
            
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
            
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.04);
            --shadow-md: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        @@media (prefers-color-scheme: dark) {
            :root {
                --card-border: rgba(255, 255, 255, 0.1);
                --divider: rgba(255, 255, 255, 0.08);
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            font-size: 15px;
            line-height: 1.4;
            background-color: var(--tg-theme-secondary-bg-color);
            color: var(--tg-theme-text-color);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            overflow-x: hidden;
        }

        .container {
            max-width: 100%;
            padding: 0 0 env(safe-area-inset-bottom, 16px) 0;
        }

        .section {
            background: var(--tg-theme-bg-color);
            margin: 8px 0;
            padding: 16px;
        }

        .section:first-child {
            margin-top: 0;
        }

        .section-title {
            font-size: 13px;
            font-weight: 500;
            color: var(--tg-theme-hint-color);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
            padding: 0 16px;
        }

        .card {
            background: var(--tg-theme-bg-color);
            border-radius: var(--radius-md);
            overflow: hidden;
        }

        .card-header {
            padding: 12px 16px;
            border-bottom: 0.5px solid var(--divider);
        }

        .card-body {
            padding: 12px 16px;
        }

        .row {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            min-height: 44px;
            gap: 12px;
        }

        .row + .row {
            border-top: 0.5px solid var(--divider);
        }

        .row-icon {
            width: 28px;
            height: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            font-size: 14px;
            flex-shrink: 0;
        }

        .row-icon.blue { background: rgba(36, 129, 204, 0.12); color: var(--tg-theme-link-color); }
        .row-icon.green { background: rgba(49, 181, 69, 0.12); color: var(--success); }
        .row-icon.orange { background: rgba(245, 166, 35, 0.12); color: var(--warning); }
        .row-icon.poly { background: rgba(0, 98, 155, 0.12); color: var(--poly-accent); }

        .row-content {
            flex: 1;
            min-width: 0;
        }

        .row-title {
            font-size: 15px;
            font-weight: 400;
        }

        .row-subtitle {
            font-size: 13px;
            color: var(--tg-theme-hint-color);
            margin-top: 2px;
        }

        .row-value {
            font-size: 15px;
            color: var(--tg-theme-hint-color);
            flex-shrink: 0;
        }

        .row-chevron {
            color: var(--tg-theme-hint-color);
            opacity: 0.5;
            font-size: 12px;
            flex-shrink: 0;
        }

        .row-clickable {
            cursor: pointer;
            transition: background-color 0.15s;
        }

        .row-clickable:active {
            background-color: var(--tg-theme-secondary-bg-color);
        }

        .progress-container {
            padding: 16px;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .progress-label {
            font-size: 14px;
            font-weight: 500;
        }

        .progress-value {
            font-size: 14px;
            color: var(--tg-theme-hint-color);
        }

        .progress-bar {
            height: 8px;
            background: var(--tg-theme-secondary-bg-color);
            border-radius: 4px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.5s ease-out;
        }

        .progress-fill.blue { background: var(--tg-theme-link-color); }
        .progress-fill.green { background: var(--success); }
        .progress-fill.yellow { background: #f0ad4e; }
        .progress-fill.red { background: var(--error); }
        .progress-fill.poly { background: var(--poly-accent); }
        .progress-fill.gold { background: var(--poly-gold); }

        .checkpoints {
            display: flex;
            justify-content: space-between;
            margin-top: 8px;
            position: relative;
        }

        .checkpoint {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

        .checkpoint-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--tg-theme-secondary-bg-color);
            border: 2px solid var(--tg-theme-hint-color);
        }

        .checkpoint-dot.completed {
            background: var(--success);
            border-color: var(--success);
        }

        .checkpoint-dot.current {
            background: var(--tg-theme-button-color);
            border-color: var(--tg-theme-button-color);
            box-shadow: 0 0 0 3px rgba(36, 129, 204, 0.2);
        }

        .checkpoint-label {
            font-size: 11px;
            color: var(--tg-theme-hint-color);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 500;
        }

        .status-badge.success {
            background: rgba(49, 181, 69, 0.12);
            color: var(--success);
        }

        .status-badge.warning {
            background: rgba(245, 166, 35, 0.12);
            color: var(--warning);
        }

        .status-badge.pending {
            background: rgba(36, 129, 204, 0.12);
            color: var(--tg-theme-link-color);
        }

        .tournament-card {
            padding: 16px;
            border-bottom: 0.5px solid var(--divider);
            cursor: pointer;
            transition: background-color 0.15s;
        }

        .tournament-card:last-child {
            border-bottom: none;
        }

        .tournament-card:active {
            background-color: var(--tg-theme-secondary-bg-color);
        }

        .tournament-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 8px;
        }

        .tournament-name {
            font-size: 15px;
            font-weight: 500;
            flex: 1;
            padding-right: 12px;
        }

        .tournament-type {
            font-size: 12px;
            padding: 3px 8px;
            border-radius: 6px;
            background: var(--tg-theme-secondary-bg-color);
            color: var(--tg-theme-hint-color);
            flex-shrink: 0;
        }

        .tournament-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            font-size: 13px;
            color: var(--tg-theme-hint-color);
        }

        .tournament-meta-item {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .tournament-result {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 10px;
            padding-top: 10px;
            border-top: 0.5px solid var(--divider);
        }

        .result-place {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 600;
        }

        .result-place.gold { background: linear-gradient(135deg, var(--poly-gold), #e8c06a); color: #fff; }
        .result-place.silver { background: linear-gradient(135deg, var(--poly-silver), #c8c8c8); color: #fff; }
        .result-place.bronze { background: linear-gradient(135deg, var(--poly-bronze), #e09550); color: #fff; }
        .result-place.default { background: var(--tg-theme-secondary-bg-color); color: var(--tg-theme-text-color); }

        .result-stats {
            display: flex;
            gap: 16px;
            font-size: 13px;
        }

        .result-stat {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .result-stat-value {
            font-weight: 600;
        }

        .nav-tabs {
            display: flex;
            background: var(--tg-theme-bg-color);
            padding: 8px;
            gap: 8px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-tab {
            flex: 1;
            padding: 10px 16px;
            border: none;
            background: transparent;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 500;
            color: var(--tg-theme-hint-color);
            cursor: pointer;
            transition: all 0.2s;
        }

        .nav-tab.active {
            background: var(--tg-theme-button-color);
            color: var(--tg-theme-button-text-color);
        }

        .profile-header {
            padding: 24px 16px;
            text-align: center;
            background: linear-gradient(180deg, var(--poly-accent) 0%, var(--poly-accent-dark) 100%);
            color: #fff;
        }

        .profile-avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 28px;
            font-weight: 600;
            backdrop-filter: blur(10px);
        }

        .profile-name {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .profile-subtitle {
            font-size: 14px;
            opacity: 0.85;
        }

        .profile-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 10px;
            padding: 6px 12px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 16px;
            font-size: 13px;
            backdrop-filter: blur(10px);
        }

        .empty-state {
            padding: 48px 24px;
            text-align: center;
        }

        .empty-state-icon {
            font-size: 48px;
            color: var(--tg-theme-hint-color);
            opacity: 0.5;
            margin-bottom: 16px;
        }

        .empty-state-title {
            font-size: 17px;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .empty-state-text {
            font-size: 14px;
            color: var(--tg-theme-hint-color);
        }

        .error-state {
            padding: 48px 24px;
            text-align: center;
        }

        .error-state-icon {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: rgba(231, 76, 60, 0.12);
            color: var(--error);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 28px;
        }

        .error-state-title {
            font-size: 17px;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .error-state-text {
            font-size: 14px;
            color: var(--tg-theme-hint-color);
            max-width: 280px;
            margin: 0 auto;
        }

        .loading-state {
            padding: 48px 24px;
            text-align: center;
        }

        .loading-spinner {
            width: 40px;
            height: 40px;
            border: 3px solid var(--tg-theme-secondary-bg-color);
            border-top-color: var(--tg-theme-button-color);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 16px;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        .loading-text {
            font-size: 14px;
            color: var(--tg-theme-hint-color);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            transition: opacity 0.15s;
            text-decoration: none;
        }

        .btn:active {
            opacity: 0.7;
        }

        .btn-primary {
            background: var(--tg-theme-button-color);
            color: var(--tg-theme-button-text-color);
        }

        .btn-secondary {
            background: var(--tg-theme-secondary-bg-color);
            color: var(--tg-theme-text-color);
        }

        .btn-link {
            background: transparent;
            color: var(--tg-theme-link-color);
            padding: 8px 0;
        }

        .btn-block {
            width: 100%;
        }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: flex-end;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s;
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background: var(--tg-theme-bg-color);
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
            width: 100%;
            max-height: 85vh;
            overflow-y: auto;
            transform: translateY(100%);
            transition: transform 0.3s;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0);
        }

        .modal-header {
            position: sticky;
            top: 0;
            background: var(--tg-theme-bg-color);
            padding: 16px;
            border-bottom: 0.5px solid var(--divider);
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 10;
        }

        .modal-title {
            font-size: 17px;
            font-weight: 600;
        }

        .modal-close {
            width: 28px;
            height: 28px;
            border: none;
            background: var(--tg-theme-secondary-bg-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--tg-theme-hint-color);
        }

        .modal-body {
            padding: 16px;
        }

        .divider {
            height: 8px;
            background: var(--tg-theme-secondary-bg-color);
        }

        .text-success { color: var(--success); }
        .text-warning { color: var(--warning); }
        .text-error { color: var(--error); }
        .text-hint { color: var(--tg-theme-hint-color); }
        .text-link { color: var(--tg-theme-link-color); }
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .font-medium { font-weight: 500; }
        .font-semibold { font-weight: 600; }

        .mt-8 { margin-top: 8px; }
        .mt-16 { margin-top: 16px; }
        .mb-8 { margin-bottom: 8px; }
        .mb-16 { margin-bottom: 16px; }
        .px-16 { padding-left: 16px; padding-right: 16px; }
        .py-8 { padding-top: 8px; padding-bottom: 8px; }

        .university-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--tg-theme-hint-color);
            padding: 4px 0;
        }

        .university-badge i {
            color: var(--poly-accent);
        }
    </style>
</head>
<body>
    <div id="app-loading" class="loading-state" style="display: none;">
        <div class="loading-spinner"></div>
        <div class="loading-text">Загрузка...</div>
    </div>
    
    <div id="app-content">
        @RenderBody()
    </div>

    <script>
        const tg = window.Telegram?.WebApp;
    	tg.ready();
        tg.expand();        

        function applyTheme() {
		    const root = document.documentElement;
            const themeParams = tg.themeParams;
            
            if (themeParams) {
                if (themeParams.bg_color)
					root.style.setProperty('--tg-theme-bg-color', themeParams.bg_color);
                if (themeParams.text_color)
					root.style.setProperty('--tg-theme-text-color', themeParams.text_color);
                if (themeParams.hint_color)
					root.style.setProperty('--tg-theme-hint-color', themeParams.hint_color);
                if (themeParams.link_color)
					root.style.setProperty('--tg-theme-link-color', themeParams.link_color);
                if (themeParams.button_color) 
					root.style.setProperty('--tg-theme-button-color', themeParams.button_color);
                if (themeParams.button_text_color)
					root.style.setProperty('--tg-theme-button-text-color', themeParams.button_text_color);
                if (themeParams.secondary_bg_color)
					root.style.setProperty('--tg-theme-secondary-bg-color', themeParams.secondary_bg_color);
            }
        }

		applyTheme();
        tg.onEvent('themeChanged', applyTheme);

        
        function initPage() {
            const loading = document.getElementById('app-loading');
            
            if (window.location.search.indexOf('initData') === -1 && tg.initData) {
                const url = new URL(window.location);
                url.searchParams.set('initData', tg.initData);
                window.location.href = url.toString();
                return;
            }
            
            loading.style.display = 'none';
        }
        
        initPage();

        function setupBackButton() {
            const path = window.location.pathname.toLowerCase();
            if (path !== '/' && path !== '/index') {
                tg.BackButton.show();
                tg.BackButton.onClick(function() {
                    const initData = new URLSearchParams(window.location.search).get('initData');
                    window.location.href = '/?initData=' + encodeURIComponent(initData || '');
                });
            } else {
                tg.BackButton.hide();
            }
        }
        setupBackButton();

        function openLichessLink(url) {
            if (tg && tg.openLink) {
                tg.openLink(url);
            } else {
                window.open(url, '_blank', 'noopener,noreferrer');
            }
        }
        
        function navigateTo(path) {
            const initData = (tg && tg.initData) ? tg.initData : '@Html.Raw(ViewData["InitData"] ?? "")';
            if (initData) {
                window.location.href = path + '?initData=' + encodeURIComponent(initData);
            } else {
                window.location.href = path;
            }
        }
        
        function showModal(modalId) {
            document.getElementById(modalId)?.classList.add('active');
        }
        
        function hideModal(modalId) {
            document.getElementById(modalId)?.classList.remove('active');
        }
        
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('modal-overlay')) {
                e.target.classList.remove('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
