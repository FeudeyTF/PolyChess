@page
@model PolyChess.Pages.UpcomingTournamentsModel
@{
    ViewData["Title"] = "Предстоящие турниры";
    ViewData["InitData"] = Model.InitData;
    
    string FormatDate(DateTime date)
    {
        return date.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"));
    }
    
    string FormatTime(DateTime date)
    {
        return date.ToString("HH:mm");
    }
    
    string GetTimeUntil(DateTime date)
    {
        var diff = date - DateTime.Now;
        if (diff.TotalMinutes < 60)
            return $"через {(int)diff.TotalMinutes} мин";
        if (diff.TotalHours < 24)
            return $"через {(int)diff.TotalHours} ч";
        if (diff.TotalDays < 7)
            return $"через {(int)diff.TotalDays} дн";
        return FormatDate(date);
    }
}

<div class="container">
    @if (!Model.IsAuthenticated)
    {
        <div class="section">
            <div class="error-state">
                <div class="error-state-icon">
                    <i class="fas fa-lock"></i>
                </div>
                <div class="error-state-title">Доступ ограничен</div>
                <div class="error-state-text">@Model.ErrorMessage</div>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="section">
            <div class="error-state">
                <div class="error-state-icon">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div class="error-state-title">Ошибка</div>
                <div class="error-state-text">@Model.ErrorMessage</div>
            </div>
        </div>
    }
    else
    {
        var startingSoon = Model.Tournaments.Where(t => t.IsStartingSoon).ToList();
        var upcoming = Model.Tournaments.Where(t => !t.IsStartingSoon).ToList();
        
        <div class="nav-tabs">
            <button class="nav-tab" onclick="navigateTo('/')">
                <i class="fas fa-user"></i> Профиль
            </button>
            <button class="nav-tab" onclick="navigateTo('/Tournaments')">
                <i class="fas fa-trophy"></i> История
            </button>
            <button class="nav-tab active" onclick="navigateTo('/UpcomingTournaments')">
                <i class="fas fa-calendar"></i> Турниры
            </button>
        </div>

        @if (startingSoon.Count > 0)
        {
            <div class="section-title">Скоро начнётся</div>
            <div class="section" style="padding: 0;">
                @foreach (var tournament in startingSoon)
                {
                    <div class="tournament-card" onclick="openLichessLink('@GetLichessUrl(tournament)')">
                        <div class="tournament-header">
                            <div class="tournament-name">@tournament.Name</div>
                            <span class="status-badge warning">
                                <i class="fas fa-clock"></i>
                                @GetTimeUntil(tournament.StartDate)
                            </span>
                        </div>
                        <div class="tournament-meta">
                            <span class="tournament-meta-item">
                                <i class="fas fa-clock"></i>
                                @FormatTime(tournament.StartDate)
                            </span>
                            <span class="tournament-meta-item">
                                <i class="fas fa-stopwatch"></i>
                                @tournament.TimeControl
                            </span>
                            @if (tournament.Duration > 0)
                            {
                                <span class="tournament-meta-item">
                                    <i class="fas fa-hourglass-half"></i>
                                    @tournament.Duration мин
                                </span>
                            }
                        </div>
                        <div class="mt-8">
                            <span class="tournament-type">@tournament.Type</span>
                        </div>
                    </div>
                }
            </div>
        }

        @if (upcoming.Count > 0)
        {
            <div class="section-title">Предстоящие турниры (@upcoming.Count)</div>
            <div class="section" style="padding: 0;">
                @foreach (var tournament in upcoming)
                {
                    <div class="tournament-card" onclick="openLichessLink('@GetLichessUrl(tournament)')">
                        <div class="tournament-header">
                            <div class="tournament-name">@tournament.Name</div>
                            <span class="tournament-type">@tournament.Type</span>
                        </div>
                        <div class="tournament-meta">
                            <span class="tournament-meta-item">
                                <i class="fas fa-calendar-alt"></i>
                                @FormatDate(tournament.StartDate)
                            </span>
                            <span class="tournament-meta-item">
                                <i class="fas fa-clock"></i>
                                @FormatTime(tournament.StartDate)
                            </span>
                            <span class="tournament-meta-item">
                                <i class="fas fa-stopwatch"></i>
                                @tournament.TimeControl
                            </span>
                            @if (tournament.Duration > 0)
                            {
                                <span class="tournament-meta-item">
                                    <i class="fas fa-hourglass-half"></i>
                                    @tournament.Duration мин
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        @if (Model.Tournaments.Count == 0)
        {
            <div class="section">
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div class="empty-state-title">Нет запланированных турниров</div>
                    <div class="empty-state-text">Новые турниры появятся здесь, когда будут запланированы</div>
                </div>
            </div>
        }

        <div class="px-16 py-8">
            <div class="university-badge">
                <i class="fas fa-graduation-cap"></i>
                Шахматный клуб СПбПУ
            </div>
        </div>
    }
</div>

@functions {
    string GetLichessUrl(UpcomingTournamentInfo tournament)
    {
        return tournament.Type == "Swiss" 
            ? $"https://lichess.org/swiss/{tournament.Id}" 
            : $"https://lichess.org/tournament/{tournament.Id}";
    }
}